---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import headerBg from '../assets/page-bg/bg-photography.jpg';

// Newest first.
const photos = Object.values(
  import.meta.glob<ImageMetadata>('../assets/photos/*.jpg', { eager: true, import: 'default' })
).reverse();
---

<Base title="Photography" description="An amateur nature photography gallery by Mohsen Tahmasebi Nasab: water, light, mountains, the field, and a dog named Olive.">
  <PageHeader
    eyebrow="// off the clock"
    title="Photography"
    lede="Outside of work I take a lot of photos. It is amateur nature photography, mostly, and a lot of it is an attempt to catch a bit of the magic of water, in whatever state I find it: rivers, coast, ice, a quiet lake at dawn. Then there is light, mountains, the occasional city at night, and my dog Olive, who is a regular subject whether she signed up for it or not. No theme here beyond what caught my eye. Click any photo to see it larger."
    bgImage={headerBg}
    bgPos="center 65%"
  />

  <section class="section section--tight">
    <div class="wrap wrap--wide">
      <div class="masonry">
        {photos.map((p, i) => (
          <button class="ph-item" type="button" data-lb-index={i} data-lb-full={p.src} data-lb-w={p.width} data-lb-h={p.height} aria-label={`Open photo ${i + 1} of ${photos.length}`}>
            <Image
              src={p}
              alt={`Photograph by Mohsen Tahmasebi Nasab (${i + 1} of ${photos.length})`}
              widths={[400, 720]}
              sizes="(max-width: 520px) 92vw, (max-width: 860px) 46vw, 30vw"
              loading={i < 6 ? 'eager' : 'lazy'}
            />
            <span class="ph-zoom" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3M11 8v6M8 11h6"/></svg>
            </span>
          </button>
        ))}
      </div>

      <p class="faint creditline">All photos © Mohsen Tahmasebi Nasab. Please ask before reusing them.</p>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" hidden aria-hidden="true">
    <div class="lb-backdrop" data-lb-close></div>
    <button class="lb-close" type="button" data-lb-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <button class="lb-nav lb-prev" type="button" data-lb-prev aria-label="Previous photo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18 9 12l6-6"/></svg>
    </button>
    <figure class="lb-stage">
      <img id="lb-img" alt="" />
      <figcaption id="lb-caption" class="lb-caption"></figcaption>
    </figure>
    <button class="lb-nav lb-next" type="button" data-lb-next aria-label="Next photo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  </div>

  <script is:inline>
    (function () {
      if (window.__lbInit) return;
      window.__lbInit = true;

      function items() { return Array.prototype.slice.call(document.querySelectorAll('.ph-item')); }
      var current = -1;

      function show(i) {
        var list = items();
        if (!list.length) return;
        current = (i + list.length) % list.length;
        var el = list[current];
        var lb = document.getElementById('lightbox');
        var img = document.getElementById('lb-img');
        var cap = document.getElementById('lb-caption');
        if (!lb || !img) return;
        img.src = el.getAttribute('data-lb-full');
        img.alt = 'Photograph by Mohsen Tahmasebi Nasab (' + (current + 1) + ' of ' + list.length + ')';
        if (cap) cap.textContent = (current + 1) + ' / ' + list.length;
        lb.hidden = false;
        lb.setAttribute('aria-hidden', 'false');
        document.documentElement.style.overflow = 'hidden';
      }
      function close() {
        var lb = document.getElementById('lightbox');
        if (!lb) return;
        lb.hidden = true;
        lb.setAttribute('aria-hidden', 'true');
        var img = document.getElementById('lb-img');
        if (img) img.removeAttribute('src');
        document.documentElement.style.overflow = '';
        current = -1;
      }

      document.addEventListener('click', function (e) {
        var t = e.target instanceof Element ? e.target : null;
        if (!t) return;
        var item = t.closest('.ph-item');
        if (item) { show(parseInt(item.getAttribute('data-lb-index'), 10) || 0); return; }
        if (t.closest('[data-lb-close]')) { close(); return; }
        if (t.closest('[data-lb-prev]')) { if (current >= 0) show(current - 1); return; }
        if (t.closest('[data-lb-next]')) { if (current >= 0) show(current + 1); return; }
      });
      document.addEventListener('keydown', function (e) {
        var lb = document.getElementById('lightbox');
        if (!lb || lb.hidden) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') show(current - 1);
        else if (e.key === 'ArrowRight') show(current + 1);
      });
      document.addEventListener('astro:before-swap', close);
    })();
  </script>
</Base>

<style>
  .masonry { column-count: 3; column-gap: 14px; }
  @media (max-width: 860px) { .masonry { column-count: 2; } }
  @media (max-width: 520px) { .masonry { column-count: 1; } }

  .ph-item {
    display: block; width: 100%; padding: 0; margin: 0 0 14px; border: 0; cursor: zoom-in;
    background: var(--bg-elev); border-radius: var(--radius-sm); overflow: hidden;
    break-inside: avoid; position: relative; line-height: 0;
    box-shadow: 0 1px 2px rgba(8,13,18,.25);
    transition: transform .22s var(--ease), box-shadow .22s var(--ease);
  }
  .ph-item :global(img) { width: 100%; height: auto; display: block; transition: transform .35s var(--ease); }
  .ph-item:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .ph-item:hover :global(img) { transform: scale(1.03); }
  .ph-zoom {
    position: absolute; right: 10px; bottom: 10px; width: 32px; height: 32px;
    display: grid; place-items: center; border-radius: 8px; color: #fff;
    background: rgba(15,22,30,.42); border: 1px solid rgba(255,255,255,.25); backdrop-filter: blur(4px);
    opacity: 0; transform: translateY(4px); transition: opacity .2s var(--ease), transform .2s var(--ease);
  }
  .ph-zoom svg { width: 16px; height: 16px; }
  .ph-item:hover .ph-zoom, .ph-item:focus-visible .ph-zoom { opacity: 1; transform: none; }

  .creditline { margin-top: 1.6rem; font-size: 0.82rem; }

  /* lightbox */
  .lightbox {
    position: fixed; inset: 0; z-index: 200;
    display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 0.5rem;
    padding: clamp(0.6rem, 3vw, 2rem);
  }
  .lightbox[hidden] { display: none; }
  .lb-backdrop { position: absolute; inset: 0; background: rgba(8,12,16,.92); backdrop-filter: blur(6px); }
  .lb-stage { position: relative; z-index: 1; margin: 0; display: flex; flex-direction: column; align-items: center; justify-self: center; max-width: 100%; }
  .lb-stage img { max-width: min(1200px, 92vw); max-height: 84vh; width: auto; height: auto; border-radius: 8px; box-shadow: 0 30px 80px rgba(0,0,0,.5); }
  .lb-caption { position: relative; z-index: 1; margin-top: 0.7rem; font: 600 0.78rem/1 var(--font-sans); letter-spacing: 0.08em; color: rgba(255,255,255,.65); }
  .lb-nav, .lb-close {
    position: relative; z-index: 1;
    display: grid; place-items: center; width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.18); color: #fff; cursor: pointer;
    transition: background .18s var(--ease), transform .18s var(--ease);
  }
  .lb-nav:hover, .lb-close:hover { background: rgba(255,255,255,.18); transform: scale(1.05); }
  .lb-nav svg { width: 22px; height: 22px; }
  .lb-close { position: absolute; top: clamp(0.6rem, 3vw, 1.4rem); right: clamp(0.6rem, 3vw, 1.4rem); width: 40px; height: 40px; }
  .lb-close svg { width: 18px; height: 18px; }
  @media (max-width: 640px) {
    .lightbox { grid-template-columns: 1fr; }
    .lb-nav { position: absolute; bottom: 1rem; }
    .lb-prev { left: 1rem; } .lb-next { right: 1rem; }
  }
</style>
