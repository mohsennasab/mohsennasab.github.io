---
import { SOCIALS } from '../consts';

interface Props {
  class?: string;
  /** "icons" = round icon buttons (default), "pills" = labelled pills */
  variant?: 'icons' | 'pills';
}
const { class: className = '', variant = 'icons' } = Astro.props;

// Tiny inline icon set (simplified marks).
function iconSvg(name: string): string {
  switch (name) {
    case 'github':
      return `<svg viewBox="0 0 24 24"><path d="M12 .5A11.5 11.5 0 0 0 .5 12 11.5 11.5 0 0 0 8.4 23c.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.3 4.6 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.3.8 1 .8 2.1v3.1c0 .3.2.7.8.6A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"/></svg>`;
    case 'linkedin':
      return `<svg viewBox="0 0 24 24"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05C21.4 8.65 22 11 22 14.1V21h-4v-6.1c0-1.45-.03-3.32-2.02-3.32-2.02 0-2.33 1.58-2.33 3.21V21h-4z"/></svg>`;
    case 'youtube':
      return `<svg viewBox="0 0 24 24"><path d="M23.5 7.2a3 3 0 0 0-2.1-2.1C19.5 4.6 12 4.6 12 4.6s-7.5 0-9.4.5A3 3 0 0 0 .5 7.2 31.2 31.2 0 0 0 0 12a31.2 31.2 0 0 0 .5 4.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.2 31.2 0 0 0 24 12a31.2 31.2 0 0 0-.5-4.8zM9.6 15.6V8.4l6.3 3.6z"/></svg>`;
    case 'scholar':
      return `<svg viewBox="0 0 24 24"><path d="M12 1 1 7l11 6 9-4.9V15h2V7zM4 13.1V17c0 1.7 3.6 3.5 8 3.5s8-1.8 8-3.5v-3.9l-8 4.4z"/></svg>`;
    case 'researchgate':
      return `<svg viewBox="0 0 24 24"><path d="M19.6 0H4.4A4.4 4.4 0 0 0 0 4.4v15.2A4.4 4.4 0 0 0 4.4 24h15.2a4.4 4.4 0 0 0 4.4-4.4V4.4A4.4 4.4 0 0 0 19.6 0zM8.5 15.7c-.3.5-1 1.1-2.1 1.1-1.9 0-3-1.6-3-3.8v-1c0-2.3 1.1-3.9 3-3.9 1.6 0 2.5.9 2.7 2.4H9.8c-.1-.8-.6-1.3-1.4-1.3-1.1 0-1.6 1-1.6 2.7v1.1c0 1.7.6 2.7 1.7 2.7.8 0 1.2-.3 1.4-.8v-1.5H8.5v-1.1h2.5v3.2c-.4.6-.9 1.1-1.5 1.5zm9.8.3h-1.6l-2.4-3.7H13v3.7h-1.4V7.4h2.9c1.9 0 3.1.9 3.1 2.6 0 1.2-.7 2.1-1.9 2.4z"/><path d="M15.2 8.5h-1.4v2.9h1.4c1.1 0 1.7-.5 1.7-1.5s-.6-1.4-1.7-1.4z"/></svg>`;
    default:
      return `<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/></svg>`;
  }
}
---

<ul class:list={['socials', `socials--${variant}`, className]}>
  {
    SOCIALS.map((s) =>
      s.href === '#' ? (
        <li>
          <span class="disabled" aria-label={`${s.label} (link coming soon)`} title={`${s.label} (link coming soon)`}>
            <span class="ico" aria-hidden="true" set:html={iconSvg(s.icon)} />
            {variant === 'pills' && <span class="lbl">{s.label}</span>}
          </span>
        </li>
      ) : (
        <li>
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} title={s.label}>
            <span class="ico" aria-hidden="true" set:html={iconSvg(s.icon)} />
            {variant === 'pills' && <span class="lbl">{s.label}</span>}
          </a>
        </li>
      )
    )
  }
</ul>

<style>
  .socials { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; margin: 0; }
  .socials a, .socials .disabled {
    display: inline-flex; align-items: center; gap: 0.45rem;
    border: 1px solid var(--border); background: var(--bg-elev); color: var(--text-dim);
    transition: color .18s var(--ease), border-color .18s var(--ease), transform .18s var(--ease), background .18s;
  }
  .socials a:hover { color: var(--text); border-color: var(--accent-line); transform: translateY(-1px); text-decoration: none; }
  .socials .disabled { opacity: 0.45; cursor: default; }
  .socials .ico { display: grid; place-items: center; }
  .socials .ico :global(svg) { width: 17px; height: 17px; display: block; fill: currentColor; }

  /* icon-only round buttons */
  .socials--icons a, .socials--icons .disabled { width: 38px; height: 38px; justify-content: center; border-radius: 10px; }

  /* labelled pills */
  .socials--pills a, .socials--pills .disabled { padding: 0.45rem 0.8rem 0.45rem 0.65rem; border-radius: 999px; font: 550 0.85rem/1 var(--font-sans); }
  .socials--pills .lbl { white-space: nowrap; }
</style>
